# Set default behavior to automatically normalize line endings
* text=auto eol=lf

# Python files
*.py text eol=lf

# Configuration files
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# Shell scripts
*.sh text eol=lf

# Documentation
*.md text eol=lf
*.rst text eol=lf
*.txt text eol=lf

# Makefiles must have LF endings
Makefile text eol=lf

# Feature files (Behave/Gherkin)
*.feature text eol=lf

# Exclude binary files from normalization
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

